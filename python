def pedir_nota(categoria):
    while True:
        try:
            nota = int(input(f"Avalie {categoria} (1 a 5): "))
            if 1 <= nota <= 5:
                return nota
            else:
                print("Digite uma nota entre 1 e 5.")
        except ValueError:
            print("Digite um número válido.")


avaliacoes = {
    "Sanduíches": pedir_nota("a qualidade dos sanduíches"),
    "Bebidas": pedir_nota("a qualidade das bebidas"),
    "Atendimento no balcão": pedir_nota("o atendimento no balcão"),
    "Atendimento à mesa": pedir_nota("o atendimento à mesa"),
    "Qualidade da maionese": pedir_nota("a qualidade da maionese"),
    "Limpeza do ambiente": pedir_nota("a limpeza do ambiente")
}

print("\nAvaliação geral:")
for categoria, nota in avaliacoes.items():
    print(f"{categoria}: {nota}")
